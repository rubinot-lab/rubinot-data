    <!-- Report Bug (AJAX lazy-load) -->
    <script>
        function openReportBug() {
            var old = document.getElementById('suggestion-modal-container');
            if (old) old.remove();

            fetch('include/suggestion_ajax.php')
                .then(function(r) { return r.text(); })
                .then(function(html) {
                    var container = document.createElement('div');
                    container.id = 'suggestion-modal-container';
                    container.innerHTML = html;
                    document.body.appendChild(container);
                    // Fill reported page URL
                    var pageInput = container.querySelector('input[name="reportedPage"]');
                    if (pageInput) pageInput.value = window.location.href;
                    Alpine.initTree(container);
                });
        }
    </script>

    <!-- Compare JS -->
