    <!-- AOS JS (local, index only) -->
    
    <!-- Sortable Tables -->
    <script src="/js/sortable-tables.js"></script>
    <script>
        
        // Sparkline tooltip component for Alpine.js
        function sparklineTooltip() {
            return {
                visible: false,
                tooltipX: 0,
                indicatorX: 0,
                indicatorY: 20,
                tooltipDate: '',
                tooltipValue: '',

                showTooltip(event) {
                    const svg = event.currentTarget.querySelector('svg');
                    const data = JSON.parse(svg.dataset.sparkline || '[]');
                    if (!data.length) return;

                    const rect = svg.getBoundingClientRect();
                    const x = event.clientX - rect.left;
                    const width = 80;
                    const height = 40;
                    const padding = 5;

                    // Find nearest data point
                    const index = Math.round((x / width) * (data.length - 1));
                    const clampedIndex = Math.max(0, Math.min(index, data.length - 1));
                    const point = data[clampedIndex];

                    // Calculate indicator X position
                    const xStep = width / (data.length - 1);
                    this.indicatorX = clampedIndex * xStep;

                    // Calculate Y based on value (need min/max)
                    const values = data.map(d => d.val);
                    const minVal = Math.min(...values);
                    const maxVal = Math.max(...values);
                    const range = maxVal - minVal || 1;
                    const chartHeight = height - padding * 2;
                    this.indicatorY = padding + chartHeight - ((point.val - minVal) / range * chartHeight);

                    // Format date
                    const date = new Date(point.ts * 1000);
                    this.tooltipDate = date.toLocaleDateString('pl-PL', {day: '2-digit', month: '2-digit', year: 'numeric'});

                    // Add time for hourly data (online players - more than 30 points)
                    if (data.length > 30) {
                        this.tooltipDate += ' ' + date.toLocaleTimeString('pl-PL', {hour: '2-digit', minute:'2-digit'});
                    }

                    // Format value (use suffix for large numbers)
                    if (point.val >= 1e12) {
                        this.tooltipValue = (point.val / 1e12).toFixed(2) + 'T';
                    } else if (point.val >= 1e9) {
                        this.tooltipValue = (point.val / 1e9).toFixed(2) + 'B';
                    } else if (point.val >= 1e6) {
                        this.tooltipValue = (point.val / 1e6).toFixed(1) + 'M';
                    } else {
                        this.tooltipValue = point.val.toLocaleString('pl-PL');
                    }

                    // Tooltip X follows indicator
                    this.tooltipX = this.indicatorX;
                    this.visible = true;
                },

                hideTooltip() {
                    this.visible = false;
                }
            }
        }

        function timelineHover(data, showAll) {
            return {
                showAllTimeline: showAll,
                tooltip: {
                    visible: false, tooltipTop: 0, arrowTop: 0,
                    nick: '', world: '', level: '', date: '',
                    indicatorY: 0, isMobile: false
                },

                handleMouseMove(event) {
                    const container = event.currentTarget;
                    const rows = container.querySelectorAll('[data-event-index]');
                    if (rows.length < 1) return;

                    const mouseY = event.clientY;

                    // Helper: determine nick at a given timestamp
                    function nickAt(ts) {
                        let n = data.currentName;
                        for (const c of data.nameChanges) { if (ts < c.date) n = c.oldName; }
                        return n;
                    }
                    // Helper: determine world at a given timestamp
                    function worldAt(ts) {
                        let w = data.currentWorld;
                        for (const c of data.worldChanges) { if (ts < c.date) w = c.world; }
                        return w;
                    }

                    // Collect Y center positions of visible event dots
                    const points = [];
                    rows.forEach(row => {
                        if (row.offsetParent === null) return;
                        const rect = row.getBoundingClientRect();
                        const centerY = rect.top + rect.height / 2;
                        const idxRaw = row.dataset.eventIndex;
                        let evt;
                        if (idxRaw === 'current') {
                            evt = data.currentEvent;
                        } else {
                            evt = data.events[parseInt(idxRaw)];
                        }
                        points.push({ y: centerY, event: evt, nick: nickAt(evt.date), world: worldAt(evt.date) });
                    });
                    if (points.length < 2) return;

                    // Clamp mouse to dot range
                    const minY = points[0].y;
                    const maxY = points[points.length - 1].y;
                    const clampedY = Math.max(minY, Math.min(mouseY, maxY));

                    // Find which segment the mouse is in
                    let prevPt = points[0], nextPt = points[points.length - 1];
                    for (let i = 0; i < points.length - 1; i++) {
                        if (clampedY >= points[i].y && clampedY <= points[i + 1].y) {
                            prevPt = points[i];
                            nextPt = points[i + 1];
                            break;
                        }
                    }

                    // Interpolation factor (0 = prevPt/newer, 1 = nextPt/older)
                    const segmentH = nextPt.y - prevPt.y;
                    const factor = segmentH > 0 ? (clampedY - prevPt.y) / segmentH : 0;

                    // Interpolate date
                    const dateA = prevPt.event.date;
                    const dateB = nextPt.event.date;
                    const interpDate = Math.round(dateA + factor * (dateB - dateA));

                    // Interpolate level
                    const lvlA = prevPt.event.lvl || 0;
                    const lvlB = nextPt.event.lvl || 0;
                    let interpLevel;
                    if (lvlA > 0 && lvlB > 0) {
                        interpLevel = Math.round(lvlA + factor * (lvlB - lvlA));
                    } else if (lvlA > 0) {
                        interpLevel = lvlA;
                    } else if (lvlB > 0) {
                        interpLevel = lvlB;
                    } else {
                        interpLevel = '?';
                    }

                    // Use nick/world from the segment's older boundary (changes exactly at event dots)
                    const nick = nextPt.nick;
                    const world = nextPt.world;

                    // Format date
                    const d = new Date(interpDate * 1000);
                    const dateStr = d.toLocaleDateString('pl-PL', {
                        day: '2-digit', month: '2-digit', year: 'numeric'
                    });

                    // Detect mobile for tooltip positioning
                    this.tooltip.isMobile = window.innerWidth < 640;

                    // Position tooltip (left of center on desktop, right of line on mobile)
                    const containerRect = container.getBoundingClientRect();
                    const containerH = container.offsetHeight;
                    const relativeY = clampedY - containerRect.top;
                    this.tooltip.indicatorY = relativeY;

                    // Measure actual tooltip height, clamp within container
                    const tooltipEl = this.$refs.timelineTooltip;
                    const tooltipH = tooltipEl ? tooltipEl.offsetHeight : 90;
                    let top = relativeY - tooltipH / 2;
                    top = Math.max(0, Math.min(top, containerH - tooltipH));
                    this.tooltip.tooltipTop = top;

                    // Arrow position relative to tooltip (follows indicator when box is clamped)
                    const arrowY = relativeY - top;
                    this.tooltip.arrowTop = Math.max(10, Math.min(arrowY, tooltipH - 10));
                    this.tooltip.nick = nick;
                    this.tooltip.world = world;
                    this.tooltip.level = (typeof interpLevel === 'number') ? interpLevel.toLocaleString() : interpLevel;
                    this.tooltip.date = '~' + dateStr;
                    this.tooltip.visible = true;
                },

                hideTooltip() {
                    this.tooltip.visible = false;
                }
            };
        }

        // Rashid locations by day (0 = Sunday)
        const rashidLocations = {
            0: 'Carlin',
            1: 'Svargrond',
            2: 'Liberty Bay',
            3: 'Port Hope',
            4: 'Ankrahmun',
            5: 'Darashia',
            6: 'Edron'
        };

        function updateRashid() {
            const now = new Date();
            const cetHours = now.getUTCHours() + 1; // CET = UTC+1
            let day = now.getUTCDay();
            if (cetHours < 10) day = (day + 6) % 7;
            const city = rashidLocations[day];
            const imgPath = '/images/rashid/' + city.toLowerCase().replace(' ', '_') + '.gif';
            // Update all rashid-city and rashid-tooltip-img elements (index + header)
            document.querySelectorAll('[id^="rashid-city"]').forEach(el => el.textContent = city);
            document.querySelectorAll('[id^="rashid-tooltip-img"]').forEach(el => el.src = imgPath);
        }

        function updateSSCountdown() {
            const now = new Date();
            const ss = new Date(now);
            ss.setUTCHours(9, 0, 0, 0); // 10:00 CET = 09:00 UTC
            if (now >= ss) ss.setUTCDate(ss.getUTCDate() + 1);

            const diff = ss - now;
            const h = Math.floor(diff / 3600000);
            const m = Math.floor((diff % 3600000) / 60000);
            const s = Math.floor((diff % 60000) / 1000);

            const timeStr = String(h).padStart(2, '0') + ':' + String(m).padStart(2, '0') + ':' + String(s).padStart(2, '0');
            document.querySelectorAll('[id^="ss-countdown"]').forEach(el => el.textContent = timeStr);
        }

        // Tibia Drome countdown (every 2 weeks on Wednesday at 10:00 CET)
        function updateDromeCountdown() {
            const now = new Date();

            // Base date: 2025-01-08 10:00:00 CET (Wednesday)
            // CET = UTC+1, so 10:00 CET = 09:00 UTC
            const baseDate = new Date(Date.UTC(2025, 0, 8, 9, 0, 0)); // January 8, 2025, 09:00 UTC

            // Calculate days since base
            const msDiff = now.getTime() - baseDate.getTime();
            const daysDiff = msDiff / (1000 * 60 * 60 * 24);

            let nextWave;
            if (daysDiff < 0) {
                // Before base date
                nextWave = new Date(baseDate);
            } else {
                // Find next wave: ceiling to next 14-day cycle
                const cyclesPassed = Math.floor(daysDiff / 14);
                nextWave = new Date(baseDate.getTime() + (cyclesPassed * 14 * 24 * 60 * 60 * 1000));

                // If we're past this wave time, go to next
                if (now >= nextWave) {
                    nextWave = new Date(nextWave.getTime() + (14 * 24 * 60 * 60 * 1000));
                }
            }

            const diff = nextWave - now;
            const days = Math.floor(diff / (1000 * 60 * 60 * 24));
            const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));

            let dromeText;
            let dromeRed = false;
            if (days > 0) {
                dromeText = days + 'd ' + hours + 'h ' + minutes + 'm';
            } else if (hours > 0) {
                dromeText = hours + 'h ' + minutes + 'm';
                dromeRed = true;
            } else {
                dromeText = minutes + 'm';
                dromeRed = true;
            }
            document.querySelectorAll('[id^="drome-countdown"]').forEach(el => {
                el.textContent = dromeText;
                if (dromeRed) {
                    el.classList.remove('text-white');
                    el.classList.add('text-red-400');
                } else {
                    el.classList.remove('text-red-400');
                    el.classList.add('text-white');
                }
            });
            document.querySelectorAll('[id^="drome-icon"]').forEach(el => {
                if (dromeRed) {
                    el.classList.add('drome-active');
                } else {
                    el.classList.remove('drome-active');
                }
            });
        }

        updateRashid();
        updateSSCountdown();
        updateDromeCountdown();
        setInterval(updateSSCountdown, 1000);
        setInterval(updateDromeCountdown, 1000);
        setInterval(updateRashid, 60000);

        // Counter animation
        function formatNumber(num) {
            return num.toString().replace(/\B(?=(\d{3})+(?!\d))/g, ' ');
        }

        function formatLargeNumber(num) {
            if (num >= 1e12) {
                return Math.round(num / 1e12) + 'T';
            } else if (num >= 1e9) {
                return Math.round(num / 1e9) + 'B';
            } else if (num >= 1e6) {
                return Math.round(num / 1e6) + 'M';
            } else {
                return formatNumber(num);
            }
        }

        function animateCounter(element) {
            const target = parseFloat(element.dataset.target);
            const format = element.dataset.format || 'default';
            const duration = 1000; // 1 second
            const startTime = performance.now();

            function easeOutQuart(t) {
                return 1 - Math.pow(1 - t, 4);
            }

            function update(currentTime) {
                const elapsed = currentTime - startTime;
                const progress = Math.min(elapsed / duration, 1);
                const easedProgress = easeOutQuart(progress);
                const current = Math.floor(easedProgress * target);

                element.textContent = format === 'large' ? formatLargeNumber(current) : formatNumber(current);

                if (progress < 1) {
                    requestAnimationFrame(update);
                } else {
                    element.textContent = format === 'large' ? formatLargeNumber(target) : formatNumber(target);
                }
            }

            requestAnimationFrame(update);
        }

        // Trigger counter animation when elements come into view
        const counterObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    animateCounter(entry.target);
                    counterObserver.unobserve(entry.target);
                }
            });
        }, { threshold: 0.5 });

        document.querySelectorAll('.counter').forEach(counter => {
            counterObserver.observe(counter);
        });

        // Sticky navbar - użycie IntersectionObserver
        const navbar = document.querySelector('nav.navbar-gradient');
        const sentinel = document.getElementById('navbar-sentinel');
        if (navbar && sentinel) {
            const navbarHeight = navbar.offsetHeight;

            // Tworzenie placeholdera
            const navbarPlaceholder = document.createElement('div');
            navbarPlaceholder.style.height = navbarHeight + 'px';
            navbarPlaceholder.style.display = 'none';
            navbar.parentNode.insertBefore(navbarPlaceholder, navbar.nextSibling);

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (!entry.isIntersecting) {
                        // Sentinel wyszedł poza viewport - przyklejamy navbar
                        navbar.style.position = 'fixed';
                        navbar.style.top = '0';
                        navbar.style.left = '0';
                        navbar.style.right = '0';
                        navbarPlaceholder.style.display = 'block';
                    } else {
                        // Sentinel jest widoczny - navbar normalnie
                        navbar.style.position = '';
                        navbar.style.top = '';
                        navbar.style.left = '';
                        navbar.style.right = '';
                        navbarPlaceholder.style.display = 'none';
                    }
                });
            }, { threshold: 0 });

            observer.observe(sentinel);
        }

        // Search autocomplete
        const searchTranslations = {
            characters: 'Characters',
            guilds: 'Guilds',
            noResults: 'No results'
        };

        function getVoc(voc) {
            const vocMap = {
                1: 'K', 2: 'EK', 3: 'P', 4: 'RP',
                5: 'S', 6: 'MS', 7: 'D', 8: 'ED',
                9: 'M', 10: 'EM'
            };
            return vocMap[voc] || '';
        }

        const searchInputs = document.querySelectorAll('.searchBox');
        searchInputs.forEach(searchInput => {
            const wrapper = searchInput.closest('.search-wrapper');
            const resultsDiv = wrapper.querySelector('.search-results');
            let debounceTimeout;

            searchInput.addEventListener('input', function() {
                const query = this.value.trim();
                clearTimeout(debounceTimeout);

                debounceTimeout = setTimeout(() => {
                    if (query.length < 2) {
                        resultsDiv.innerHTML = '';
                        return;
                    }

                    fetch('include/search.php?q=' + encodeURIComponent(query))
                        .then(response => response.json())
                        .then(data => {
                            let html = '';

                            if (data.players.length > 0) {
                                html += '<div class="group"><strong>' + searchTranslations.characters + ':</strong>';
                                data.players.forEach(player => {
                                    var name = player.name.replace(/&apos;/g, "'");
                                    html += `<a class="result-item" href="character/${encodeURIComponent(name)}">${name}<div class="c-xs">${player.lvl} lvl - ${getVoc(player.voc)} - ${player.world}</div></a>`;
                                });
                                html += '</div>';
                            }

                            if (data.guilds.length > 0) {
                                html += '<div class="group"><strong>' + searchTranslations.guilds + ':</strong>';
                                data.guilds.forEach(guild => {
                                    html += `<a class="result-item" href="guild/${encodeURIComponent(guild.name)}">${guild.name}<div class="c-xs">${guild.world}</div></a>`;
                                });
                                html += '</div>';
                            }

                            resultsDiv.innerHTML = html || '<div class="no-results">' + searchTranslations.noResults + '</div>';
                        })
                        .catch(() => {
                            resultsDiv.innerHTML = '';
                        });
                }, 400);
            });

            // Close results on click outside
            document.addEventListener('click', function(event) {
                if (!wrapper.contains(event.target)) {
                    resultsDiv.innerHTML = '';
                }
            });

            // Close results on form submit (if in a form)
            const parentForm = searchInput.closest('form');
            if (parentForm) {
                parentForm.addEventListener('submit', function() {
                    resultsDiv.innerHTML = '';
                });
            }
        });
    </script>

    <!-- CSRF token auto-inject for AJAX -->
    <script>
    (function() {
        var token = document.querySelector('meta[name="csrf-token"]');
        if (!token) return;
        token = token.content;

        var origFetch = window.fetch;
        window.fetch = function(url, opts) {
            opts = opts || {};
            if (opts.method && opts.method.toUpperCase() === 'POST') {
                if (opts.body instanceof FormData) {
                    opts.body.append('csrf_token', token);
                } else if (typeof opts.body === 'string') {
                    opts.body += (opts.body ? '&' : '') + 'csrf_token=' + encodeURIComponent(token);
                }
            }
            return origFetch.call(this, url, opts);
        };

        var origOpen = XMLHttpRequest.prototype.open;
        var origSend = XMLHttpRequest.prototype.send;
        XMLHttpRequest.prototype.open = function(method) {
            this._csrfMethod = method;
            return origOpen.apply(this, arguments);
        };
        XMLHttpRequest.prototype.send = function(body) {
            if (this._csrfMethod && this._csrfMethod.toUpperCase() === 'POST') {
                if (body instanceof FormData) {
                    body.append('csrf_token', token);
                } else if (typeof body === 'string') {
                    body += (body ? '&' : '') + 'csrf_token=' + encodeURIComponent(token);
                }
            }
            return origSend.call(this, body);
        };
    })();
    </script>
</body>
</html>
